ORCHESTRATOR_API_KEY=replace-with-a-long-random-key
ORCHESTRATOR_BIND_IP=127.0.0.1
ORCHESTRATOR_PORT=8090
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
ORCHESTRATOR_IMAGE=local/local-llm-orchestrator:latest

LLAMA_CPP_IMAGE=ghcr.io/ggml-org/llama.cpp:server
LLAMA_CPP_CUDA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda
LLAMA_MODELS_MAX=2
LLAMA_SLEEP_IDLE_SECONDS=900
REQUEST_TIMEOUT_SECONDS=300

MCP_ENABLED=false
MCP_SERVER_URL=http://host.docker.internal:8765/mcp
MCP_TOOL_ALLOWLIST=route_request,build_agent_context,load_skill,load_workflow,list_toolsets,get_toolset

