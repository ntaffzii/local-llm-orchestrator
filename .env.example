LLAMA_SERVER_EXE=llama-server
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080
LLAMA_MODELS_MAX=2
LLAMA_CTX_SIZE=8192
LLAMA_SLEEP_IDLE_SECONDS=900

ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8090
ORCHESTRATOR_WORKERS=1
