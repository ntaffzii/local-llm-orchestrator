REQUEST_TIMEOUT_SECONDS=300
ORCHESTRATOR_LOG_LEVEL=INFO
ORCHESTRATOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

MCP_ENABLED=false
MCP_SERVER_URL=http://127.0.0.1:8765/mcp
MCP_TOOL_ALLOWLIST=
